# CloudOps Change Guard — 環境変数サンプル（実値は .env＝git追跡外にコピーして使う）
# cp .env.example .env して値を埋める。.env は絶対にコミットしない（CLAUDE.md §5-6）。

# ---- DB ----
DB_URL=jdbc:postgresql://localhost:5436/cloudops
DB_USER=cloudops
DB_PASSWORD=cloudops

# ---- JWT（本番は必ず32バイト以上の強いランダム値に置換。コミット禁止） ----
JWT_SECRET=change-me-32-bytes-minimum-random-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
JWT_COOKIE_SECURE=false

# ---- CORS（フロントは 5177 固定。ワイルドカード禁止＝SEC-11） ----
CORS_ALLOWED_ORIGIN=http://localhost:5177

# ---- seed（初期ユーザー） ----
SEED_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!2026
SEED_DEFAULT_PASSWORD=demo
